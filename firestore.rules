rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidUser(data) {
      return data.uid == request.auth.uid 
        && data.email is string && data.email.size() > 0
        && data.keys().hasAll(['uid', 'email'])
        && data.keys().size() <= 6;
    }

    function isValidSession(data) {
      return data.userId == request.auth.uid
        && data.title is string && data.title.size() > 0 && data.title.size() <= 500
        && data.createdAt == request.time
        && data.keys().hasAll(['userId', 'title', 'createdAt'])
        && data.keys().size() <= 10;
    }

    // Rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) 
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt;

      match /sessions/{sessionId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSession(incoming()) && isValidId(sessionId);
        allow update: if isOwner(userId) && isValidSession(incoming()) 
          && incoming().userId == existing().userId
          && incoming().createdAt == existing().createdAt;
        allow delete: if isOwner(userId);
      }
    }
  }
}
